# shotAI builds/ships x64 and runs emulated on Windows-on-ARM (see docs/PLAN.md).
# target_arch=x64 makes get-windows' node-pre-gyp fetch its win32-x64 prebuild
# (it ships no arm64 prebuild) during `npm install`, instead of failing on a
# source build. The x64 Electron binary and node-screenshots' x64 package are
# provisioned by scripts/postinstall.mjs (npm 11 gates dependency install
# scripts; root-package scripts are exempt, so it always runs).
#
# NOTE: npm 11 warns this key is "Unknown project config" and will stop working
# in npm 12; revisit then. The postinstall repairs x64 regardless — this just
# keeps get-windows' own install script from aborting the install.
target_arch=x64
